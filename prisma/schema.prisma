generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  STANDARD
  PLATFORM_ADMIN
}

enum MembershipRole {
  OWNER
  ADMIN
  VIEWER
}

enum AssessmentStatus {
  DRAFT
  COLLECTING
  SCORED
  REPORTED
  ARCHIVED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  PASS
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  systemRole     SystemRole   @default(STANDARD)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]
}

model Tenant {
  id                  String                 @id @default(cuid())
  name                String
  slug                String                 @unique
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  memberships         Membership[]
  assessments         Assessment[]
  trainingCampaigns   TrainingCampaign[]
  phishingSimulations PhishingSimulation[]
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  tenantId  String
  role      MembershipRole
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Assessment {
  id             String                 @id @default(cuid())
  tenantId       String
  title          String
  status         AssessmentStatus       @default(DRAFT)
  sourceMode     String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers        Answer[]
  evidences      Evidence[]
  findings       RiskFinding[]
  scoreSnapshots ScoreSnapshot[]
  reports        Report[]
}

model Question {
  id         String   @id
  domain     String
  prompt     String
  type       String
  weight     Int
  required   Boolean  @default(true)
  options    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  answers    Answer[]
}

model Answer {
  id           String     @id @default(cuid())
  tenantId     String
  assessmentId String
  questionId   String
  value        Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
}

model IntegrationConnection {
  id            String   @id @default(cuid())
  tenantId      String
  provider      String
  status        String
  externalRef   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Evidence {
  id           String     @id @default(cuid())
  tenantId     String
  assessmentId String
  domain       String
  provider     String
  title        String
  payload      Json
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model RiskFinding {
  id             String     @id @default(cuid())
  tenantId       String
  assessmentId   String
  domain         String
  severity       Severity
  title          String
  impact         String
  recommendation String
  evidenceRefs   Json
  createdAt      DateTime   @default(now())
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id           String     @id @default(cuid())
  tenantId     String
  assessmentId String
  totalScore   Float
  domainScores Json
  status       Severity
  summary      Json
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model Report {
  id             String     @id @default(cuid())
  tenantId       String
  assessmentId   String
  snapshotId     String
  generatedAt    DateTime   @default(now())
  snapshot       Json
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model TrainingCampaign {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String
  completion   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PhishingSimulation {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  template           String
  employeeCount      Int
  submittedCount     Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  meta        Json
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}
